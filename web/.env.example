# Frontend reads the shared root .env by default through Vite envDir.
# Add local VITE_* overrides here only if you explicitly want to diverge.
# The root .env controls frontend tuning like:
# FRONTEND_TYPEWRITER_INTERVAL_MS=42
# FRONTEND_TYPEWRITER_CHARS_PER_TICK=3
# FRONTEND_REWORK_BEACON_DURATION_MS=10000
